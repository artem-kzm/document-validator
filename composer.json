{
    "name": "app/document-validator",
    "type": "project",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "pestphp/pest": "^4.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
